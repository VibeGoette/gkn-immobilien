# Lokale Entwicklung: alle Vercel-/Sanity-Vars per
#   vercel env pull .env.local
# aus dem mit der Vercel-Sanity-Marketplace-Integration verbundenen
# Projekt ziehen. Diese Datei dokumentiert nur, welche Vars erwartet
# werden — Werte selbst sind im Vercel-Dashboard hinterlegt.

# ─── Sanity (von Vercel-Marketplace-Integration auto-provisioniert) ───
# Public (client-side):
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Server-side Mirrors (gleiche Werte wie public, ohne NEXT_PUBLIC_-Prefix):
SANITY_PROJECT_ID=
SANITY_DATASET=production

# API-Version (manuell, nicht von Vercel gesetzt):
NEXT_PUBLIC_SANITY_API_VERSION=2026-04-28

# Tokens (server-side, secret):
# - Read Token: Draft-Mode / Preview
# - Write Token: lokale Seed-Skripte + Migrations
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=

# ─── Site ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://gkn-immobilien.de

# ─── Optional ────────────────────────────────────────────────────────
# Webhook-Revalidation für Sanity → Next.js ISR-Invalidate
SANITY_REVALIDATE_SECRET=
